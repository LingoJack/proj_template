# 服务配置
APP_SERVER_HOST=0.0.0.0
APP_SERVER_PORT=8080

# 数据库
APP_DATABASE_DRIVER=mysql
APP_DATABASE_DSN=user:pass@tcp(localhost:3306)/appdb?charset=utf8mb4&parseTime=True&loc=Local

# 日志
APP_LOG_LEVEL=info
APP_LOG_FORMAT=json
APP_LOG_OUTPUT=stdout

# 中间件
APP_MIDDLEWARE_AUTH_ENABLED=false
APP_MIDDLEWARE_AUTH_JWT_SECRET=change-me-in-production
APP_MIDDLEWARE_AUTH_JWT_EXPIRY_HOURS=24
APP_MIDDLEWARE_RATE_LIMIT_ENABLED=false
APP_MIDDLEWARE_CORS_ENABLED=true
